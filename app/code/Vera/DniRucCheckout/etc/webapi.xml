<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/guest-carts/:cartId/vera-receipt" method="POST">
        <service class="Vera\DniRucCheckout\Api\ReceiptInformationManagementInterface" method="saveGuest"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
    <route url="/V1/guest-carts/:cartId/vera-receipt" method="GET">
        <service class="Vera\DniRucCheckout\Api\ReceiptInformationManagementInterface" method="getGuest"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
    <route url="/V1/carts/mine/vera-receipt" method="POST">
        <service class="Vera\DniRucCheckout\Api\ReceiptInformationManagementInterface" method="saveMine"/>
        <resources>
            <resource ref="self"/>
        </resources>
    </route>
    <route url="/V1/carts/mine/vera-receipt" method="GET">
        <service class="Vera\DniRucCheckout\Api\ReceiptInformationManagementInterface" method="getMine"/>
        <resources>
            <resource ref="self"/>
        </resources>
    </route>
</routes>
